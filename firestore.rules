rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.get('email', '').lower() in [
          "fernando.campos.gruporb@gmail.com",
          "fecampos120@gmail.com",
          "fcampos120@gmail.com"
        ]) ||
        request.auth.uid == "9eKuuQvm28V6b2H7DD23JDQLbLG2"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /suppliers/{supplierId} {
      allow read, write: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }

    match /units/{unitId} {
      allow read, write: if isSignedIn();
    }

    match /service_categories/{categoryId} {
      allow read, write: if isSignedIn();
    }

    match /contracts/{contractId} {
      allow get, list, create, update, delete: if isSignedIn();
      
      match /attachments/{attachmentId} {
        allow get, list, create, update, delete: if isSignedIn();
      }
    }

    match /processos/{processoId} {
      allow get, list, create, update, delete: if isSignedIn();
      
      match /attachments/{attachmentId} {
        allow get, list, create, update, delete: if isSignedIn();
      }
    }

    match /procedure_settings/{settingsId} {
      allow read, write: if isSignedIn();
    }

    match /company_settings/{settingsId} {
      allow read, write: if isSignedIn();
    }

    match /visits/{visitId} {
      // Portaria search requires reading visits
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /followup_projects/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /followup_history/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

