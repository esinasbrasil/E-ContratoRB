rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          "fernando.campos.gruporb@gmail.com",
          "fecampos120@gmail.com"
        ] ||
        request.auth.uid == "9eKuuQvm28V6b2H7DD23JDQLbLG2"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /test/connection {
      allow read: if isSignedIn();
    }

    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      // Allow creation by authenticated users for onboarding (if needed)
      allow create: if isSignedIn();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /service_categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(request.resource.data.user_id);
      
      match /attachments/{attachmentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /processos/{processoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /procedure_settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /company_settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /visits/{visitId} {
      // Allow authenticated users to read and write visits
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}

