{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier homologated in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "address": { "type": "string" },
        "serviceType": { "type": "string" },
        "status": { "type": "string", "enum": ["Homologado", "Aguardando", "Bloqueado"] },
        "rating": { "type": "number" },
        "docs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "cnpj", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "An engineering project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "unitId": { "type": "string" },
        "costCenter": { "type": "string" },
        "orderNumber": { "type": "string" },
        "description": { "type": "string" },
        "estimatedValue": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "type": { "type": "string", "enum": ["Improvement", "Adaptation", "Acquisition", "Renovation", "Compliance", "Maintenance", "Other"] },
        "status": { "type": "string", "enum": ["Active", "Completed", "Planned", "On Hold"] },
        "attachments": { "type": "array" },
        "requiredNRs": { "type": "array" }
      },
      "required": ["name", "unitId", "status"]
    },
    "Unit": {
      "title": "Unit",
      "description": "A business unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "cnpj": { "type": "string" },
        "ie": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name", "cnpj"]
    },
    "ServiceCategory": {
      "title": "ServiceCategory",
      "description": "A category of service provided by suppliers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Contract": {
      "title": "Contract",
      "description": "A contract generated in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "projectId": { "type": "string" },
        "supplierId": { "type": "string" },
        "value": { "type": "number" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Legal Review", "Signed"] },
        "details": { "type": "object" }
      },
      "required": ["projectId", "supplierId", "status"]
    },
    "Procedure": {
      "title": "Procedure",
      "description": "A progress tracker for the contracting process with smart deadline control",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "projectId": { "type": "string" },
        "supplierId": { "type": "string" },
        "projectName": { "type": "string" },
        "supplierName": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["internal", "supplier", "final"] },
              "standardDurationDays": { "type": "number" },
              "startDate": { "type": "string" },
              "limitDate": { "type": "string" },
              "completedDate": { "type": "string" },
              "isParallel": { "type": "boolean" }
            }
          }
        },
        "status": { "type": "string", "enum": ["In Progress", "Completed", "Delayed"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["projectId", "projectName", "steps", "status", "createdAt"]
    },
    "CompanySettings": {
      "title": "CompanySettings",
      "description": "Global settings for the company",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "logoBase64": { "type": "string" },
        "footerText": { "type": "string" },
        "primaryColor": { "type": "string" },
        "documentTitle": { "type": "string" }
      }
    },
    "Visit": {
      "title": "Visit",
      "description": "An access authorization for the gatehouse (portaria)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "cnpj": { "type": "string" },
        "companyName": { "type": "string" },
        "carPlate": { "type": "string" },
        "reason": { "type": "string" },
        "authorizedBy": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Authorized", "Completed", "Canceled"] },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "cpf", "status", "startDate"]
    },
    "FollowUpProject": {
      "title": "FollowUpProject",
      "description": "A project for follow-up tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unit": { "type": "string" },
        "projectNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["unit", "projectNumber"]
    },
    "FollowUpHistory": {
      "title": "FollowUpHistory",
      "description": "Historical comment for a follow-up project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectNumber": { "type": "string" },
        "date": { "type": "string" },
        "comment": { "type": "string" }
      },
      "required": ["projectNumber", "date", "comment"]
    }
  },
  "firestore": {
    "/followup_projects/{id}": {
      "schema": "FollowUpProject",
      "description": "Projects for follow-up tracking"
    },
    "/followup_history/{id}": {
      "schema": "FollowUpHistory",
      "description": "Comments and history for follow-up projects"
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Visits and access authorizations collection"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Suppliers collection"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects collection"
    },
    "/units/{unitId}": {
      "schema": "Unit",
      "description": "Units collection"
    },
    "/service_categories/{categoryId}": {
      "schema": "ServiceCategory",
      "description": "Service categories collection"
    },
    "/contracts/{contractId}": {
      "schema": "Contract",
      "description": "Contracts collection"
    },
    "/processos/{processoId}": {
      "schema": "Procedure",
      "description": "Procedures tracking collection"
    },
    "/company_settings/{settingsId}": {
      "schema": "CompanySettings",
      "description": "Company settings collection"
    }
  }
}
